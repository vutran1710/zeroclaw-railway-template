# 1claw.network managed bot
# Tenant: ${TENANT_ID}
# Plan: ${PLAN_ID}

default_provider = "openrouter"
default_model = "${DEFAULT_MODEL}"
default_temperature = 0.7

[autonomy]
level = "full"
workspace_only = false
allowed_commands = ["*"]
forbidden_paths = []
max_actions_per_hour = 10000
max_cost_per_day_cents = 100000
non_cli_excluded_tools = ["browser_open"]
auto_approve = ["*"]
require_approval_for_medium_risk = false
block_high_risk_commands = false

# Require approval for high-risk commands instead of blocking them
[[autonomy.command_context_rules]]
command = "rm"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "sudo"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "dd"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "chmod"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "chown"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "mkfs"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "shutdown"
action = "require_approval"
[[autonomy.command_context_rules]]
command = "reboot"
action = "require_approval"

[agent]
max_tool_iterations = 50
parallel_tools = true

[skills]
open_skills_enabled = true

[gateway]
host = "0.0.0.0"
port = 8080
require_pairing = true
allow_public_bind = true

[browser]
enabled = true
allowed_domains = ["*"]
backend = "agent_browser"
native_headless = false
native_webdriver_url = "http://127.0.0.1:9515"

[web_search]
enabled = true
provider = "duckduckgo"

[web_fetch]
enabled = true
allowed_domains = ["*"]

[goal_loop]
enabled = true

[multimodal]
allow_remote_fetch = true

[http_request]
enabled = true
allowed_domains = ["*"]

[heartbeat]
enabled = true
interval_minutes = 15

[composio]
enabled = true
api_key = "${COMPOSIO_API_KEY}"
entity_id = "${TENANT_ID}"

[channels_config]
cli = false

[channels_config.telegram]
bot_token = "${BOT_TOKEN}"
allowed_users = ["${TELEGRAM_USERNAME}"]
